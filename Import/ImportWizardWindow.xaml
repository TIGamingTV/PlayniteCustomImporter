<Window x:Class="PlayniteCustomImporter.Import.ImportWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Import Game"
        Height="480" Width="640"
        WindowStartupLocation="CenterOwner"
        MinHeight="380" MinWidth="480">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Step indicator -->
        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,12">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelectSourceStep}" Value="True">
                            <Setter Property="Text" Value="Step 1 of 3 — Select the game folder" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsChooseStorageStep}" Value="True">
                            <Setter Property="Text" Value="Step 2 of 3 — Choose a storage location" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsPickExecutableStep}" Value="True">
                            <Setter Property="Text" Value="Step 3 of 3 — Pick the executable" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Body -->
        <Grid Grid.Row="1">
            <!-- Step 1: select source -->
            <StackPanel Visibility="{Binding IsSelectSourceStep, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Click Import to browse for the game folder you want to add. Browsing starts in the configured source folder."
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />
                <Button Content="Import..."
                        HorizontalAlignment="Left"
                        Padding="20,6"
                        Command="{Binding ImportCommand}" />
                <TextBlock Text="Selected folder:"
                           FontWeight="Bold"
                           Margin="0,16,0,4" />
                <TextBlock Text="{Binding SelectedSourceFolder}"
                           TextWrapping="Wrap"
                           Opacity="0.8" />
            </StackPanel>

            <!-- Step 2: choose storage -->
            <DockPanel Visibility="{Binding IsChooseStorageStep, Converter={StaticResource BoolToVis}}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Select where the folder should be moved. Manage these locations in the plugin settings."
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                <TextBlock DockPanel.Dock="Bottom"
                           Margin="0,8,0,0"
                           Opacity="0.7"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsChooseStorageStep, Converter={StaticResource BoolToVis}}"
                           Text="{Binding SelectedSourceFolder, StringFormat=Folder to move: {0}}" />
                <ListBox ItemsSource="{Binding StorageLocations}"
                         SelectedItem="{Binding SelectedStorage}"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DisplayName}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FreeSpaceDisplay}"
                                           Margin="12,0,0,0"
                                           Opacity="0.7"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Step 3: pick executable -->
            <DockPanel Visibility="{Binding IsPickExecutableStep, Converter={StaticResource BoolToVis}}">
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                <Button DockPanel.Dock="Bottom"
                        Content="Browse for another .exe..."
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0"
                        Command="{Binding BrowseExeCommand}" />
                <ListBox ItemsSource="{Binding FoundExecutables}"
                         SelectedItem="{Binding SelectedExecutable}"
                         DisplayMemberPath="FileName" />
            </DockPanel>
        </Grid>

        <!-- Navigation -->
        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <Button DockPanel.Dock="Left"
                    Content="Back"
                    MinWidth="80"
                    Command="{Binding BackCommand}"
                    Visibility="{Binding IsChooseStorageStep, Converter={StaticResource BoolToVis}}" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        MinWidth="80"
                        Margin="0,0,8,0"
                        Command="{Binding CancelCommand}" />
                <Button Content="Next"
                        MinWidth="80"
                        Command="{Binding MoveAndNextCommand}"
                        Visibility="{Binding IsChooseStorageStep, Converter={StaticResource BoolToVis}}" />
                <Button Content="Add to Playnite"
                        MinWidth="120"
                        Command="{Binding AddGameCommand}"
                        Visibility="{Binding IsPickExecutableStep, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
