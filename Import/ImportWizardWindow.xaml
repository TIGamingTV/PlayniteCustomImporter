<Window x:Class="PlayniteCustomImporter.Import.ImportWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Import Game"
        Height="480" Width="640"
        WindowStartupLocation="CenterOwner"
        MinHeight="380" MinWidth="480"
        Background="#1E1E1E"
        Foreground="#E6E6E6"
        FontSize="13">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Dark text field -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30" />
            <Setter Property="Foreground" Value="#E6E6E6" />
            <Setter Property="CaretBrush" Value="#E6E6E6" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <!-- Dark list -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#252526" />
            <Setter Property="Foreground" Value="#E6E6E6" />
            <Setter Property="BorderBrush" Value="#3F3F46" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E6E6E6" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="itemBorder"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#333337" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#094771" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base button: custom template so Background actually applies -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="#3D3D3D" />
            <Setter Property="BorderBrush" Value="#6E6E6E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7A7A7A" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#9A9A9A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2A2A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Step indicator -->
        <TextBlock Grid.Row="0"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,12">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelectSourceStep}" Value="True">
                            <Setter Property="Text" Value="Step 1 of 3 — Select the game folder" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsChooseStorageStep}" Value="True">
                            <Setter Property="Text" Value="Step 2 of 3 — Choose a storage location" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsPickExecutableStep}" Value="True">
                            <Setter Property="Text" Value="Step 3 of 3 — Pick the executable" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Body -->
        <Grid Grid.Row="1">
            <!-- Step 1: select source -->
            <StackPanel Visibility="{Binding IsSelectSourceStep, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Click Import to browse for the game folder you want to add. Browsing starts in the configured source folder."
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />
                <Button Content="Import..."
                        Style="{StaticResource DarkButton}"
                        Background="#5E5E5E"
                        HorizontalAlignment="Left"
                        Padding="24,8"
                        Command="{Binding ImportCommand}" />
                <TextBlock Text="Selected folder:"
                           FontWeight="Bold"
                           Margin="0,16,0,4" />
                <TextBlock Text="{Binding SelectedSourceFolder}"
                           TextWrapping="Wrap"
                           Foreground="#B8B8B8" />
            </StackPanel>

            <!-- Step 2: choose storage -->
            <DockPanel Visibility="{Binding IsChooseStorageStep, Converter={StaticResource BoolToVis}}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Select where the folder should be moved. Manage these locations in the plugin settings."
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                <TextBlock DockPanel.Dock="Bottom"
                           Margin="0,8,0,0"
                           Foreground="#9A9A9A"
                           TextWrapping="Wrap"
                           Text="{Binding SelectedSourceFolder, StringFormat=Folder to move: {0}}" />
                <ListBox ItemsSource="{Binding StorageLocations}"
                         SelectedItem="{Binding SelectedStorage}"
                         DisplayMemberPath="DisplayName" />
            </DockPanel>

            <!-- Step 3: pick executable -->
            <DockPanel Visibility="{Binding IsPickExecutableStep, Converter={StaticResource BoolToVis}}">
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                <Button DockPanel.Dock="Bottom"
                        Content="Browse for another .exe..."
                        Style="{StaticResource DarkButton}"
                        Background="#474747"
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0"
                        Command="{Binding BrowseExeCommand}" />
                <ListBox ItemsSource="{Binding FoundExecutables}"
                         SelectedItem="{Binding SelectedExecutable}"
                         DisplayMemberPath="FileName" />
            </DockPanel>
        </Grid>

        <!-- Navigation -->
        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <Button DockPanel.Dock="Left"
                    Content="Back"
                    Style="{StaticResource DarkButton}"
                    Background="#333333"
                    Command="{Binding BackCommand}"
                    Visibility="{Binding IsChooseStorageStep, Converter={StaticResource BoolToVis}}" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource DarkButton}"
                        Background="#3D3D3D"
                        Margin="0,0,8,0"
                        Command="{Binding CancelCommand}" />
                <Button Content="Next"
                        Style="{StaticResource DarkButton}"
                        Background="#545454"
                        Command="{Binding MoveAndNextCommand}"
                        Visibility="{Binding IsChooseStorageStep, Converter={StaticResource BoolToVis}}" />
                <Button Content="Add to Playnite"
                        Style="{StaticResource DarkButton}"
                        Background="#6A6A6A"
                        MinWidth="120"
                        Command="{Binding AddGameCommand}"
                        Visibility="{Binding IsPickExecutableStep, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
